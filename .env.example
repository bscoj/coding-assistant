# Make a copy of this to set environment variables for local development
# cp .env.example .env

# Databricks authentication
# Recommended team setup:
#   databricks auth login --profile DEFAULT --host https://<your-workspace>.databricks.com
#   databricks auth profiles
# Then keep the same profile name here.
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# Optional if you want tracing / feedback support
MLFLOW_EXPERIMENT_ID=

CHAT_APP_SERVER_PORT=3001
CHAT_APP_CLIENT_PORT=3002
CHAT_PROXY_TIMEOUT_SECONDS=300
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# Main Databricks Model Serving endpoint used by the coding assistant
AGENT_MODEL_ENDPOINT=databricks-gpt-5-2
# Optional UI/backend allowlist for model switching. Comma-separated.
# AGENT_AVAILABLE_MODEL_ENDPOINTS=databricks-gpt-5-2,another-endpoint

# Local conversation memory settings
MEMORY_ENABLED=true
MEMORY_DB_PATH=.local/conversation_memory.db
# lean is cheaper, work is the recommended coding default, raw keeps far more of the thread verbatim.
MEMORY_MODE=work
MEMORY_SUMMARY_THRESHOLD_MESSAGES=10
MEMORY_RECENT_MESSAGES=12
MEMORY_WORK_SUMMARY_THRESHOLD_MESSAGES=12
MEMORY_WORK_RECENT_MESSAGES=60
MEMORY_RAW_SUMMARY_THRESHOLD_MESSAGES=20
MEMORY_RAW_RECENT_MESSAGES=140
MEMORY_MIN_FACT_CONFIDENCE=0.65
MEMORY_MAX_SUMMARY_WORDS=450
MEMORY_WORK_MAX_SUMMARY_WORDS=1000
MEMORY_RAW_MAX_SUMMARY_WORDS=1600
# Optional override; defaults to AGENT_MODEL_ENDPOINT
# MEMORY_MODEL_ENDPOINT=databricks-gpt-5-2

# Persistent cross-conversation user profile
USER_PROFILE_ENABLED=true
# personalized injects durable user/project profile context; fresh ignores it.
CONTEXT_MODE=personalized
USER_PROFILE_PATH=.local/user_profile.json
PROJECT_PROFILE_DIR=.local/project_profiles
USER_PROFILE_MIN_CONFIDENCE=0.82
USER_PROFILE_MAX_ITEMS=24
# Optional override; defaults to MEMORY_MODEL_ENDPOINT, then AGENT_MODEL_ENDPOINT
# USER_PROFILE_MODEL_ENDPOINT=databricks-gpt-5-2

# Local filesystem tools
FILES_WORKSPACE_ROOT=.
FILES_WRITE_ENABLED=true
FILES_STAGED_WRITES_PATH=.local/staged_writes.json
FILES_WORKSPACE_INDEX_PATH=.local/workspace_index.json
FILES_MAX_READ_BYTES=40000
FILES_MAX_READ_LINES=160
FILES_MAX_SEARCH_RESULTS=25
FILES_MAX_SEARCH_LINE_CHARS=320
FILES_MAX_TOOL_OUTPUT_CHARS=12000

# Caps large tool outputs before they are sent to the background memory summarizer.
MEMORY_TOOL_SUMMARY_MAX_CHARS=1200

# Runtime hook/event instrumentation
RUNTIME_HOOKS_ENABLED=true
RUNTIME_HOOK_EVENT_LOG_PATH=.local/runtime_hook_events.jsonl

# Validated SQL memory
SQL_MEMORY_DB_PATH=.local/sql_memory.db
